# 🚀 NPM 性能优化配置

# 优先使用离线缓存
prefer-offline=true

# 增加网络超时和重试次数
fetch-retries=5
fetch-retry-mintimeout=10000
fetch-retry-maxtimeout=60000
fetch-timeout=300000

# 跳过不必要的检查以加速安装
audit=false
fund=false
update-notifier=false

# 使用并行下载
maxsockets=50

# 缓存优化
cache-min=9999999

# 严格使用 package-lock.json
package-lock=true

# 进度条禁用（在 CI/CD 环境中更快）
progress=false
